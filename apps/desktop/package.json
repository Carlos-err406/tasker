{
  "name": "@tasker/desktop",
  "version": "3.13.0",
  "description": "Tasker - lightweight task manager",
  "author": "Carlos",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "electron-builder --config electron-builder.json5 --publish=never",
    "clean": "rm -rf dist dist-electron",
    "test:e2e": "pnpm build && playwright test --config playwright.config.ts",
    "test:e2e:debug": "pnpm build && playwright test --config playwright.config.ts --headed --timeout 0"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@tasker/core": "workspace:*",
    "chokidar": "^4.0.0",
    "cmdk": "^1.1.1",
    "electron-traywindow-positioner": "^1.2.0",
    "radix-ui": "^1.4.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "optionalDependencies": {
    "eventkit-node": "^1.0.3"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "lucide-react": "^0.469.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^3.0.0"
  }
}
